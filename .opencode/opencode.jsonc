{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "oxlint": {
      "command": "node_modules/.bin/oxlint",
      "args": ["--lsp"],
      "filetypes": ["javascript", "typescript", "javascriptreact", "typescriptreact", "vue"],
      "rootPatterns": [".oxlintrc.json", "package.json"],
      "settings": {
        "configPath": ".oxlintrc.json",
      },
    },
  },
  "formatters": {
    "javascript": "oxfmt",
    "typescript": "oxfmt",
    "vue": "oxfmt",
  },
  "linters": {
    "javascript": "oxlint",
    "typescript": "oxlint",
    "vue": "oxlint",
  },
}
