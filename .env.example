# Environment Configuration for TwirChat

# Backend Configuration
CHATRIX_BACKEND_URL=http://127.0.0.1:3000
CHATRIX_BACKEND_WS_URL=ws://127.0.0.1:3000/ws

# Development ports
AUTH_SERVER_PORT=45821
OVERLAY_SERVER_PORT=45823
KICK_WEBHOOK_PORT=45822

# Database
DB_PATH=~/.twirchat/db.sqlite

# App Info
APP_NAME=TwirChat
