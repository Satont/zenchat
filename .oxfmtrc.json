{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "semi": false,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.out/**",
    "**/gen/**",
    "**/*.d.ts",
    "**/coverage/**",
    "**/.opencode/**",
    "**/*.graphql",
    "**/*.proto",
    "**/.sisyphus/**"
  ]
}
