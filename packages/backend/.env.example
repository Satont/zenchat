# Backend environment variables
# Copy this file to .env and fill in the values.

# ── Server ────────────────────────────────────────────────────
# Port the HTTP + WebSocket server listens on.
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────
# Bun.sql reads DATABASE_URL (or POSTGRES_URL / PGURL) automatically.
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://zenchat:zenchat@localhost:5432/zenchat

# ── Kick OAuth ────────────────────────────────────────────────
# Register your app at https://kick.com/settings/developer
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Where Kick redirects after OAuth. Must match the redirect URI
# registered in your Kick app settings.
# For local dev: http://localhost:3000/auth/kick/callback
KICK_REDIRECT_URI=http://localhost:3000/auth/kick/callback

# ── Kick Webhooks ─────────────────────────────────────────────
# The public HTTPS URL where Kick will POST webhook events.
# In local dev, use a tunnel (e.g. ngrok):
#   ngrok http 3000
#   → set this to https://<your-id>.ngrok.io/webhook/kick
KICK_WEBHOOK_URL=https://your-backend.example.com/webhook/kick

# The secret used to verify Kick webhook HMAC signatures.
# Generate with: openssl rand -hex 32
KICK_WEBHOOK_SECRET=
