{
  "name": "@zenchat/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --config vite.main.config.ts build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --config vite.main.config.ts --port 5173",
    "typecheck": "tsgo --noEmit",
    "test": "bun test tests/",
    "build:prod": "vite --config vite.main.config.ts build && electrobun build --env=canary"
  },
  "dependencies": {
    "@zenchat/shared": "workspace:*",
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0",
    "@twurple/api": "8.0.3",
    "@twurple/auth": "8.0.3",
    "@twurple/chat": "8.0.3",
    "bun-plugin-vue": "1.0.0",
    "electrobun": "1.16.0",
    "vue": "3.5.30"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "6.0.5",
    "concurrently": "9.2.1",
    "vite": "8.0.1"
  }
}
