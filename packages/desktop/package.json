{
  "name": "@twirchat/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "electrobun dev",
    "dev": "bun run --parallel hmr start",
    "hmr": "vite --config vite.main.config.ts --port 5173",
    "build:views": "vite build --config vite.main.config.ts && vite build --config vite.overlay.config.ts",
    "gen": "cd src/platforms/youtube && bunx @bufbuild/buf generate",
    "typecheck": "tsgo --noEmit",
    "test": "bun test tests/",
    "build:prod": "bun run build:views && electrobun build --env=stable",
    "build:prod:ci": "bun run build:views && CHATRIX_BACKEND_URL=$CHATRIX_BACKEND_URL CHATRIX_BACKEND_WS_URL=$CHATRIX_BACKEND_WS_URL electrobun build --env=stable"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@grpc/grpc-js": "1.14.3",
    "@twirchat/shared": "workspace:*",
    "@twurple/api": "8.0.3",
    "@twurple/auth": "8.0.3",
    "@twurple/chat": "8.0.3",
    "electrobun": "1.16.0",
    "reka-ui": "2.9.2",
    "vue": "3.5.30"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.66.1",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "6.0.5",
    "ts-proto": "2.11.6",
    "vite": "8.0.1"
  }
}
